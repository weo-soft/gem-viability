{
  "name": "skill-support-compatibility-viewer",
  "version": "0.1.0",
  "description": "Static web app to browse Path of Exile–style skill and support gems and their compatibility",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/weo-soft/gem-viability.git"
  },
  "bugs": {
    "url": "https://github.com/weo-soft/gem-viability/issues"
  },
  "homepage": "https://gem-viability.weosoft.org/",
  "scripts": {
    "dev": "node scripts/generate-gems-json.js && vite",
    "build": "node scripts/generate-gems-json.js && vite build",
    "build:gh-pages": "node scripts/generate-gems-json.js && BASE_PATH=/gem-viability/ vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "vite": "^8.0.3",
    "vitest": "^2.1.4"
  }
}
