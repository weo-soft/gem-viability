{
  "name": "skill-support-compatibility-viewer",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-gems-json.js && vite",
    "build": "node scripts/generate-gems-json.js && vite build",
    "build:gh-pages": "node scripts/generate-gems-json.js && BASE_PATH=/gem-viability/ vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.4"
  }
}
